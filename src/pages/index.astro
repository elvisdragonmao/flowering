---
import Header from "../components/Header.astro";
import RoseScene from "../components/RoseScene.astro";
import "../styles/global.css";

const services = [
	{
		title: "客製花束",
		text: "依照送禮對象、場合、預算與色系，設計專屬於當下心意的花束。"
	},
	{
		title: "送禮花藝",
		text: "花盒、花籃、節慶花禮與開幕祝賀，讓祝福以更細膩的方式抵達。"
	},
	{
		title: "婚禮花藝",
		text: "從新娘捧花、胸花到婚禮場地佈置，以花藝勾勒儀式感與記憶。"
	},
	{
		title: "活動佈置",
		text: "為品牌活動、派對、展覽、攝影場景與空間陳列打造花藝視覺。"
	}
];

const processSteps = [
	["提出需求", "分享日期、場合、預算、色系與希望傳達的感覺。"],
	["討論風格", "依照季節花材與使用情境，提供花藝方向與搭配建議。"],
	["確認訂製", "確認尺寸、款式、日期與取貨／配送方式。"],
	["完成作品", "由花藝師親手製作，保留花材自然姿態與專屬美感。"]
];

// 可替換：未來可把這些作品圖改成真實作品檔名或 CMS 資料。
const moments = [
	{ src: "/img/flower/flower1.webp", alt: "朝花曦時花藝作品 01" },
	{ src: "/img/flower/flower2.webp", alt: "朝花曦時花藝作品 02" },
	{ src: "/img/flower/flower3.webp", alt: "朝花曦時花藝作品 03" },
	{ src: "/img/flower/flower4.webp", alt: "朝花曦時花藝作品 04" },
	{ src: "/img/flower/flower5.webp", alt: "朝花曦時花藝作品 05" },
	{ src: "/img/flower/flower6.webp", alt: "朝花曦時花藝作品 06" },
	{ src: "/img/flower/flower7.webp", alt: "朝花曦時花藝作品 07" },
	{ src: "/img/flower/flower8.webp", alt: "朝花曦時花藝作品 08" }
];

// 可替換：花藝師經歷、年資與品牌實績可日後更新。
const experience = ["AFA 美國花藝設計學院 現代花藝設計教授"];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="朝花曦時藝術工作室，提供客製花束、送禮花藝、婚禮花藝、活動佈置與空間花藝設計。" />
		<title>朝花曦時藝術工作室</title>
		<link rel="preconnect" href="https://font.emtech.cc" />
		<link rel="stylesheet" href="https://font.emtech.cc/css/ChironSungHK" />
		<link rel="stylesheet" href="https://font.emtech.cc/css/ZhuqueFangsong" />
	</head>
	<body data-loading>
		<div class="site-loader" data-site-loader aria-live="polite" aria-label="網站載入中">
			<div class="loader-mark">
				<span>朝花曦時</span>
				<small>藝術工作室</small>
			</div>
			<div class="loader-line" aria-hidden="true"></div>
		</div>

		<Header />
		<RoseScene />

		<main id="top">
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-grid">
					<div class="hero-content">
						<p class="hero-kicker">Bespoke Floral Design</p>
						<h1 class="hero-title title-reveal" id="hero-title">
							<span class="title-line">朝花</span>
							<span class="title-line">曦時</span>
						</h1>
						<p class="hero-copy">在晨光與花影之間，為你設計一份剛好的美好。</p>
						<p class="hero-subcopy">客製花藝設計，獻給每一份值得被好好傳遞的心意。</p>
						<div class="hero-actions">
							<a class="button-primary" href="#contact">預約客製花禮</a>
						</div>
					</div>

					<aside class="editorial-note reveal" aria-label="雜誌式品牌文字">
						<span class="cover-word">Floral<br />Art<br />Studio</span>
						<div class="edition-meta">
							<span>Premium Boutique Studio</span>
							<span>Soft Cinematic Floral Direction</span>
						</div>
					</aside>
				</div>
			</section>

			<div class="intro-strip reveal" aria-hidden="true">
				<span>Issue 01 / Morning Light & Flowers</span>
				<span>Custom Bouquet / Wedding / Spatial Art</span>
			</div>

			<section class="page-section about" id="about" aria-labelledby="about-title">
				<div class="section-inner about-statement">
					<p class="eyebrow reveal">About</p>
					<p class="about-poem reveal" id="about-title">
						每朵花都不該被辜負<br />
						每個故事都會被尊重和珍視<br />
						擁有故事輪廓的花束<br />
						等待收花人揭曉這份<br />
						驚喜和幸福。
					</p>
				</div>
			</section>

			<section class="page-section artist" id="artist" aria-labelledby="artist-title">
				<div class="section-inner artist-panel">
					<div class="reveal">
						<p class="eyebrow">Artist</p>
						<h2 class="section-title" id="artist-title">田曦之</h2>
						<p class="artist-role">花藝師 / Artist</p>
						<ol class="experience-list artist-experience stagger-reveal">
							{
								experience.map((item, index) => (
									<li>
										<span>{String(index + 1).padStart(2, "0")}</span>
										<p>{item}</p>
									</li>
								))
							}
						</ol>
					</div>

					<div class="artist-media reveal">
						<!-- 可替換：花藝師照片可改為正式形象照。 -->
						<img src="/img/flower/artist.webp" alt="花藝師田曦之" loading="lazy" />
					</div>
				</div>
			</section>

			<section class="page-section services" id="services" aria-labelledby="services-title">
				<div class="section-inner">
					<div class="services-header reveal">
						<div>
							<p class="eyebrow">Services</p>
							<h2 class="section-title" id="services-title">服務項目</h2>
						</div>
						<p class="section-deck">從一束花到一場儀式，依照用途、空間與情緒設計專屬花藝。</p>
					</div>

					<div class="services-grid stagger-reveal">
						{
							services.map((service, index) => (
								<article class="service-card">
									<span class="number">{String(index + 1).padStart(2, "0")}</span>
									<div>
										<h3>{service.title}</h3>
										<p>{service.text}</p>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="page-section moments" id="moments" aria-labelledby="moments-title">
				<div class="section-inner">
					<div class="moments-header reveal">
						<div>
							<p class="eyebrow">Gallery</p>
							<h2 class="section-title" id="moments-title">作品</h2>
						</div>
					</div>

					<div class="moments-grid stagger-reveal">
						{
							moments.map(item => (
								<figure class="moment parallax-panel">
									<img src={item.src} alt={item.alt} loading="lazy" />
								</figure>
							))
						}
					</div>
				</div>
			</section>

			<section class="page-section process" aria-labelledby="process-title">
				<div class="section-inner">
					<div class="process-header reveal">
						<div>
							<p class="eyebrow">Process</p>
							<h2 class="section-title" id="process-title">客製流程</h2>
						</div>
						<p class="section-deck">以清楚的討論節奏，保留每束花的自然感與訂製細節。</p>
					</div>

					<ol class="process-list stagger-reveal">
						{
							processSteps.map(([title, text], index) => (
								<li class="process-step">
									<span>{String(index + 1).padStart(2, "0")}</span>
									<h3>{title}</h3>
									<p>{text}</p>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<section class="page-section contact" id="contact" aria-labelledby="contact-title">
				<div class="section-inner">
					<div class="reveal">
						<p class="eyebrow">Contact</p>
						<h2 class="contact-title" id="contact-title">與我們一起設計一份花的心意。</h2>
					</div>

					<div class="contact-card reveal">
						<p>歡迎透過 Instagram 私訊洽詢客製花藝、活動佈置與婚禮花藝需求。請提供日期、用途、預算、喜歡的色系與參考風格，我們會協助你規劃最合適的花藝作品。</p>
						<!-- 可替換：正式上線前請改為實際 Instagram 帳號。 -->
						<a class="button-primary" href="https://www.instagram.com/tiffany.tian.7/" target="_blank" rel="noreferrer">前往 Instagram 洽詢</a>
					</div>
				</div>

				<footer class="site-footer">
					<span>朝花曦時藝術工作室</span>
					<span>Floral Art Studio / Bespoke Floral Design</span>
				</footer>
			</section>
		</main>
	</body>
</html>
