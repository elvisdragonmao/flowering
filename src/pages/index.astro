---
import Header from "../components/Header.astro";
import RoseScene from "../components/RoseScene.astro";
import "../styles/global.css";

const services = [
	{
		title: "客製花束",
		text: "依照送禮對象、場合、預算與色系，設計專屬於當下心意的花束。"
	},
	{
		title: "送禮花藝",
		text: "花盒、花籃、節慶花禮與開幕祝賀，讓祝福以更細膩的方式抵達。"
	},
	{
		title: "婚禮花藝",
		text: "從新娘捧花、胸花到婚禮場地佈置，以花藝勾勒儀式感與記憶。"
	},
	{
		title: "活動佈置",
		text: "為品牌活動、派對、展覽、攝影場景與空間陳列打造花藝視覺。"
	}
];

const processSteps = [
	["提出需求", "分享日期、場合、預算、色系與希望傳達的感覺。"],
	["討論風格", "依照季節花材與使用情境，提供花藝方向與搭配建議。"],
	["確認訂製", "確認尺寸、款式、日期與取貨／配送方式。"],
	["完成作品", "由花藝師親手製作，保留花材自然姿態與專屬美感。"]
];

// 可替換：未來可把這些 placeholder 改成真實作品圖片與分類。
const moments = [
	["生日花束", "Birthday Bouquet", "linear-gradient(135deg, #9b6f67, #dcc6ae 45%, #683d42)"],
	["婚禮捧花", "Wedding Bouquet", "linear-gradient(135deg, #ebe0d0, #b98489 58%, #46513f)"],
	["開幕花禮", "Opening Gift", "linear-gradient(135deg, #394235, #b89a63 48%, #f1e4d1)"],
	["品牌活動", "Brand Event", "linear-gradient(135deg, #251f1e, #7b1f2c 52%, #c9aa71)"],
	["空間佈置", "Spatial Floral", "linear-gradient(135deg, #68705a, #e1d1bd 52%, #a65c62)"],
	["節慶送禮", "Seasonal Gift", "linear-gradient(135deg, #f4eadc, #b56b70 58%, #2f2b27)"]
];

// 可替換：花藝師經歷、年資與品牌實績可日後更新。
const experience = [
	"花藝設計經歷｜X 年",
	"專注於客製花束、婚禮花藝與活動佈置",
	"參與品牌活動、節慶花禮與私人訂製花藝設計",
	"擅長以自然線條、柔和色彩與季節花材呈現作品情緒",
	"預留更多經歷條目，方便日後替換"
];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="朝花曦時藝術工作室，提供客製花束、送禮花藝、婚禮花藝、活動佈置與空間花藝設計。" />
		<title>朝花曦時藝術工作室｜Bespoke Floral Design</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&family=Noto+Serif+TC:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<Header />
		<RoseScene />

		<main id="top">
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-grid">
					<div class="hero-content stagger-reveal">
						<p class="hero-kicker">Bespoke Floral Design</p>
						<h1 class="hero-title title-reveal" id="hero-title">
							<span class="title-line">朝花</span>
							<span class="title-line">曦時</span>
						</h1>
						<p class="hero-copy">在晨光與花影之間，為你設計一份剛好的美好。</p>
						<p class="hero-subcopy">客製花藝設計，獻給每一份值得被好好傳遞的心意。</p>
						<div class="hero-actions">
							<a class="button-primary" href="#contact">預約客製花禮</a>
						</div>
					</div>

					<aside class="editorial-note reveal" aria-label="雜誌式品牌文字">
						<span class="cover-word">Floral<br />Art<br />Studio</span>
						<div class="edition-meta">
							<span>Premium Boutique Studio</span>
							<span>Soft Cinematic Floral Direction</span>
						</div>
					</aside>
				</div>
			</section>

			<div class="intro-strip reveal" aria-hidden="true">
				<span>Issue 01 / Morning Light & Flowers</span>
				<span>Custom Bouquet / Wedding / Spatial Art</span>
			</div>

			<section class="page-section about" id="about" aria-labelledby="about-title">
				<div class="section-inner split-layout">
					<div class="reveal">
						<p class="eyebrow">About</p>
						<h2 class="section-title" id="about-title">季節、線條與心意的比例</h2>
						<p class="lead">以季節花材、自然線條與色彩美學，為送禮、婚禮、活動與生活儀式設計專屬花藝作品。</p>
					</div>
					<div class="about-aside reveal">
						<span class="aside-number">01</span>
						<p class="aside-text">我們相信花藝不是裝飾，而是一種替人說話的方式。色彩、姿態與留白，都為當下的情感找到剛好的位置。</p>
					</div>
				</div>
			</section>

			<section class="page-section artist" id="artist" aria-labelledby="artist-title">
				<div class="section-inner artist-panel">
					<div class="reveal">
						<p class="eyebrow">Artist</p>
						<h2 class="section-title" id="artist-title">花藝師 / Artist</h2>
						<blockquote class="artist-quote">
							她相信，每朵花都不該被辜負。<br />
							每個故事，都值得被尊重和珍視。<br />
							因此，每一件作品都不只是花材的排列，而是情感、時間與記憶的輪廓。
						</blockquote>
					</div>

					<ol class="experience-list stagger-reveal">
						{
							experience.map((item, index) => (
								<li>
									<span>{String(index + 1).padStart(2, "0")}</span>
									<p>{item}</p>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<section class="page-section quote-section" aria-label="詩意品牌文案">
				<div class="section-inner">
					<p class="eyebrow reveal">Poetic Statement</p>
					<p class="poem reveal">
						每朵花都不該被辜負<br />
						每個故事都會被尊重和珍視<br />
						擁有故事輪廓的花束<br />
						等待收花人揭曉這份<br />
						驚喜和幸福。
					</p>
					<p class="poem-note reveal">A bouquet with the silhouette of a story, waiting to be received.</p>
				</div>
			</section>

			<section class="page-section services" id="services" aria-labelledby="services-title">
				<div class="section-inner">
					<div class="services-header reveal">
						<div>
							<p class="eyebrow">Services</p>
							<h2 class="section-title" id="services-title">服務項目</h2>
						</div>
						<p class="section-deck">從一束花到一場儀式，依照用途、空間與情緒設計專屬花藝。</p>
					</div>

					<div class="services-grid stagger-reveal">
						{
							services.map((service, index) => (
								<article class="service-card">
									<span class="number">{String(index + 1).padStart(2, "0")}</span>
									<div>
										<h3>{service.title}</h3>
										<p>{service.text}</p>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="page-section process" aria-labelledby="process-title">
				<div class="section-inner">
					<div class="process-header reveal">
						<div>
							<p class="eyebrow">Process</p>
							<h2 class="section-title" id="process-title">客製流程</h2>
						</div>
						<p class="section-deck">以清楚的討論節奏，保留每束花的自然感與訂製細節。</p>
					</div>

					<ol class="process-list stagger-reveal">
						{
							processSteps.map(([title, text], index) => (
								<li class="process-step">
									<span>{String(index + 1).padStart(2, "0")}</span>
									<h3>{title}</h3>
									<p>{text}</p>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<section class="page-section moments" id="moments" aria-labelledby="moments-title">
				<div class="section-inner">
					<div class="moments-header reveal">
						<div>
							<p class="eyebrow">Gallery / Moments</p>
							<h2 class="section-title" id="moments-title">作品情境</h2>
						</div>
						<p class="section-deck">目前使用可替換 placeholder，未來可直接改為真實作品圖片。</p>
					</div>

					<div class="moments-grid stagger-reveal">
						{
							moments.map(([label, note, bg]) => (
								<article class="moment parallax-panel" style={`--moment-bg: ${bg};`}>
									<span class="moment-label">{label}</span>
									<span class="moment-note">{note}</span>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="page-section contact" id="contact" aria-labelledby="contact-title">
				<div class="section-inner">
					<div class="reveal">
						<p class="eyebrow">Contact</p>
						<h2 class="contact-title" id="contact-title">與我們一起設計一份花的心意。</h2>
					</div>

					<div class="contact-card reveal">
						<p>歡迎透過 Instagram 私訊洽詢客製花藝、活動佈置與婚禮花藝需求。請提供日期、用途、預算、喜歡的色系與參考風格，我們會協助你規劃最合適的花藝作品。</p>
						<!-- 可替換：正式上線前請改為實際 Instagram 帳號。 -->
						<a class="button-primary" href="https://www.instagram.com/your_ig_account" target="_blank" rel="noreferrer">前往 Instagram 洽詢</a>
					</div>
				</div>

				<footer class="site-footer">
					<span>朝花曦時藝術工作室</span>
					<span>Floral Art Studio / Bespoke Floral Design</span>
				</footer>
			</section>
		</main>
	</body>
</html>
