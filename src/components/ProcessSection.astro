---
const processSteps = [
	["提出需求", "分享日期、場合、預算、色系與希望傳達的感覺。"],
	["討論風格", "依照季節花材與使用情境，提供花藝方向與搭配建議。"],
	["確認訂製", "確認尺寸、款式、日期與取貨／配送方式。"],
	["完成作品", "由花藝師親手製作，保留花材自然姿態與專屬美感。"]
];
---

<section class="page-section process" aria-labelledby="process-title">
	<div class="section-inner">
		<div class="process-header reveal">
			<div>
				<p class="eyebrow">Process</p>
				<h2 class="section-title" id="process-title">客製流程</h2>
			</div>
			<p class="section-deck">以清楚的討論節奏，保留每束花的自然感與訂製細節。</p>
		</div>

		<ol class="process-list stagger-reveal">
			{
				processSteps.map(([title, text], index) => (
					<li class="process-step">
						<span>{String(index + 1).padStart(2, "0")}</span>
						<h3>{title}</h3>
						<p>{text}</p>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.process {
		background: rgba(104, 112, 90, 0.09);
	}

	.process-header {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 2rem;
		margin-bottom: clamp(2rem, 5vw, 4rem);
	}

	.process-list {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
		border-top: 1px solid rgba(104, 112, 90, 0.28);
	}

	.process-step {
		min-height: 20rem;
		padding: clamp(1.2rem, 2.5vw, 2rem);
		border-right: 1px solid rgba(104, 112, 90, 0.24);
	}

	.process-step:last-child {
		border-right: 0;
	}

	.process-step span {
		color: var(--muted-olive);
		font-family: var(--font-display);
		font-size: 3rem;
		line-height: 1;
	}

	.process-step h3 {
		margin: 4rem 0 0;
		font-size: 1.25rem;
		font-weight: 600;
	}

	.process-step p {
		margin: 1rem 0 0;
		color: rgba(36, 33, 31, 0.62);
	}

	@media (max-width: 980px) {
		.process-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.process-step:nth-child(2) {
			border-right: 0;
		}
	}

	@media (max-width: 720px) {
		.process-header {
			flex-direction: column;
			align-items: start;
		}

		.process-list {
			grid-template-columns: 1fr;
		}

		.process-step {
			min-height: auto;
			border-right: 0;
			border-bottom: 1px solid rgba(104, 112, 90, 0.24);
		}

		.process-step h3 {
			margin-top: 2.6rem;
		}
	}
</style>
